rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // SOS media: only the uploader can write, only admin/police/owner can read
    match /sos_media/{userId}/{allPaths=**} {
      // Only the authenticated user who owns the folder can upload
      allow write: if request.auth != null
                   && request.auth.uid == userId;

      // Owner, admin (custom claim), or authenticated police can read
      allow read: if request.auth != null
                  && (
                    request.auth.uid == userId
                    || request.auth.token.role == 'admin'
                    || request.auth.token.role == 'police'
                  );
    }

    // Default: deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
